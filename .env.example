APP_NAME=NovaHire
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=novahire
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
LIVEWIRE_TEMPORARY_FILE_UPLOAD_DISK=local
LIVEWIRE_TEMP_MAX_UPLOAD_KB=20480
LIVEWIRE_PAYLOAD_MAX_SIZE_BYTES=15728640
LIVEWIRE_MAX_UPLOAD_TIME_MINUTES=10
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-brevo-smtp-login@example.com
MAIL_PASSWORD=your-brevo-smtp-key
MAIL_FROM_ADDRESS="no-reply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Cloudinary (profile image storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional unified URL format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=
CLOUDINARY_FOLDER=novahire
CLOUDINARY_TIMEOUT=15

VITE_APP_NAME="${APP_NAME}"
VITE_BROADCAST_DRIVER=pusher
VITE_REALTIME_ENABLED=false
REALTIME_NOTIFICATIONS_ENABLED=false
VITE_PUSHER_APP_KEY=local-reverb-key
VITE_PUSHER_HOST=127.0.0.1
VITE_PUSHER_PORT=8080
VITE_PUSHER_SCHEME=http
VITE_PUSHER_APP_CLUSTER=mt1

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

REVERB_APP_ID=local-reverb-app
REVERB_APP_KEY=local-reverb-key
REVERB_APP_SECRET=local-reverb-secret
REVERB_SERVER_HOST=0.0.0.0
REVERB_HOST=127.0.0.1
REVERB_HOSTNAME=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
OPENAI_REQUEST_TIMEOUT=45
AI_ANALYSIS_MODEL=gpt-4o-mini
AI_ANALYSIS_MAX_TOKENS=900
AI_ANALYSIS_TIME_LIMIT=120
AI_MAX_CV_CHARS=3500
AI_MAX_JOB_DESC_CHARS=1800
AI_USE_OPENAI_EXTRACT=false
AI_EXTRACT_MODEL=gpt-4o-mini
AI_EXTRACT_MAX_TOKENS=450
AI_EXTRACT_TIME_LIMIT=60
# In local with QUEUE_CONNECTION=sync, enable one of these to allow real GPT calls:
AI_ALLOW_OPENAI_WITH_SYNC_QUEUE=false
AI_FORCE_OPENAI=false

AI_NOTE_MODEL=gpt-4o-mini
AI_NOTE_MAX_TOKENS=420
PHASE2_REJECT_MAX_SCORE=50
PHASE2_SHORTLIST_MAX_SCORE=70
PHASE3_DIGEST_SEND_TIME=07:30
PHASE3_EMAIL_DEDUPE_MINUTES=30
PHASE4_DEFAULT_TIMEZONE=Europe/London
PHASE4_SLOT_DURATION_MINUTES=45
PHASE4_BUFFER_MINUTES=10
PHASE4_WEEKEND_ENABLED=false
PHASE4_AUTO_GENERATE_DAYS=28
PHASE4_DEFAULT_MODE=video
UK_TIMEZONE=Europe/London
UK_BANK_HOLIDAYS_URL=https://www.gov.uk/bank-holidays.json
UK_BANK_HOLIDAYS_DIVISION=england-and-wales
UK_BANK_HOLIDAYS_CACHE_HOURS=168
UK_BANK_HOLIDAYS_TIMEOUT=8

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_TIMEOUT=10

# Maps and geocoding
# Supported providers: geoapify, google
MAPS_PROVIDER=geoapify
MAPS_LOCALE=en
MAPS_HTTP_TIMEOUT=5
MAPS_HTTP_RETRY_TIMES=2
MAPS_HTTP_RETRY_SLEEP_MS=200
MAPS_LOG_FAILURES=true

# Google Maps provider (optional fallback; keep empty when using Geoapify)
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_COUNTRY=

# Geoapify provider (recommended no-card setup)
# Required: GEOAPIFY_API_KEY
# Optional: GEOAPIFY_COUNTRY as ISO 3166-1 alpha-2, e.g. gb, us, ae
# For United Kingdom use `gb`, not `uk`
GEOAPIFY_API_KEY=
GEOAPIFY_COUNTRY=
GEOAPIFY_BASE_URL=https://api.geoapify.com
GEOAPIFY_MAPS_BASE_URL=https://maps.geoapify.com
GEOAPIFY_AUTOCOMPLETE_PATH=/v1/geocode/autocomplete
GEOAPIFY_SEARCH_PATH=/v1/geocode/search
GEOAPIFY_REVERSE_PATH=/v1/geocode/reverse
GEOAPIFY_PLACE_DETAILS_PATH=/v2/place-details
GEOAPIFY_ROUTING_PATH=/v1/routing
GEOAPIFY_MAPMATCHING_PATH=/v1/mapmatching
GEOAPIFY_TILE_PATH=/v1/tile/carto/{z}/{x}/{y}.png
GEOAPIFY_STATIC_MAP_PATH=/v1/staticmap
GEOAPIFY_AUTOCOMPLETE_LIMIT=8

STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_BASIC_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_ANNUAL=
# Backward compatibility fallback keys:
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

BILLING_DEFAULT_TRIAL_DAYS=30
BILLING_INDIVIDUAL_MONTHLY_TRIAL_DAYS=30
BILLING_ANNUAL_DISCOUNT_PERCENT=20
